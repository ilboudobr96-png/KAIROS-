{
  "version": 2,
  "name": "kairos-resilience-hub",
  "buildCommand": null,
  "outputDirectory": "public",
  "routes": [
    {
      "src": "/api/claude",
      "dest": "/api/claude.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "functions": {
    "api/claude.js": {
      "maxDuration": 30
    }
  }
}
